{
  "installCommand": "npm install --include=dev",
  "buildCommand": "cd frontend && npm install --include=dev && npm run build",
  "builds": [
    {
      "src": "api/**/*.ts",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/products(?:/(.*))?",
      "dest": "/api/products.ts"
    },
    {
      "src": "/api/orders(?:/(.*))?",
      "dest": "/api/orders.ts"
    },
    {
      "src": "/(.*\\.(js|css|png|svg|ico|json|woff2|woff|ttf|eot))$",
      "dest": "/frontend/$1"
    },
    {
      "src": "/$",
      "dest": "/frontend/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/index.html"
    }
  ]
}
